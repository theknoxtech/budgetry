SECRET_KEY=change-this-to-a-random-string

# Optional: Auth0 (leave blank for local-only auth)
AUTH0_DOMAIN=
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=

# Optional: Plaid bank sync
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox

# Optional: Litestream SQLite replication
# Replicate your database to S3-compatible storage for automatic backups.
# Leave blank to disable. Examples:
#   S3:             s3://bucket-name/budgetry.db
#   Cloudflare R2:  s3://bucket-name/budgetry.db (with R2 endpoint below)
#   Local path:     /backups/budgetry.db
LITESTREAM_REPLICA_URL=

# Required only if using S3/R2 replication:
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# For Cloudflare R2, set the endpoint:
# AWS_ENDPOINT_URL=https://<account-id>.r2.cloudflarestorage.com
